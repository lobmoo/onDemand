{
  "LoggerConfig": {
    "FileName": "./dsfc.log",
    "LogType": "both",
    "LogLevel": "error",
    "MaxFileSize": 1,
    "MaxBackupIndex": 10,
    "IsAsync": false,
    "FlushOnLevel": "error",
    "ConsoleLogLevel": "error",
    "FileLogLevel": "error",
    "LogPattern": "[%Y-%m-%d %H:%M:%S.%e] [%^%l%$] [%t] [%s:%# %!] %v"
  }
}