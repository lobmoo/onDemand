        eprosima::fastcdr::Cdr& cdr,
        DSF::Var::VarRequest& data)
{
    using namespace DSF::Var;

    cdr.deserialize_type(eprosima::fastcdr::CdrVersion::XCDRv2 == cdr.get_cdr_version() ?
            eprosima::fastcdr::EncodingAlgorithmFlag::DELIMIT_CDR2 :
            eprosima::fastcdr::EncodingAlgorithmFlag::PLAIN_CDR,
            [&data](eprosima::fastcdr::Cdr& dcdr, const eprosima::fastcdr::MemberId& mid) -> bool
            {
                bool ret_value = true;
                if (0 == mid.id)
                {
                    DSF::Var::DEFINE_TYPE discriminator;
                    dcdr >> discriminator;

                    switch (discriminator)
                    {
                                                case DSF::Var::DEFINE_TYPE::VAR_DEFINE:
                                                    {
                                                        DSF::Var::Define varDefine_value;
                                                        data.varDefine(std::move(varDefine_value));
                                                        data._d(discriminator);
                                                        break;
                                                    }

                                                case DSF::Var::DEFINE_TYPE::VAR_UNDEFINE:
                                                    {
                                                        DSF::Var::Undefine varUndefine_value;
                                                        data.varUndefine(std::move(varUndefine_value));
                                                        data._d(discriminator);
                                                        break;
                                                    }

                        default:
                            data._default();
                            break;
                    }
                }
                else
                {
                    switch (data._d())
                    {
                                                case DSF::Var::DEFINE_TYPE::VAR_DEFINE:
                                                    dcdr >> data.varDefine();
                                                    break;

                                                case DSF::Var::DEFINE_TYPE::VAR_UNDEFINE:
                                                    dcdr >> data.varUndefine();
                                                    break;

                        default:
                            break;
                    }
                    ret_value = false;
                }
                return ret_value;
            });
}

