        << eprosima::fastcdr::MemberId(4) << data.properties()
;
    scdr.end_serialize_type(current_state);
}

template<>
eProsima_user_DllExport void deserialize(
        eprosima::fastcdr::Cdr& cdr,
        DSF::Var::TableDataTransferEx& data)
{
    using namespace DSF::Var;

    cdr.deserialize_type(eprosima::fastcdr::CdrVersion::XCDRv2 == cdr.get_cdr_version() ?
            eprosima::fastcdr::EncodingAlgorithmFlag::DELIMIT_CDR2 :
            eprosima::fastcdr::EncodingAlgorithmFlag::PLAIN_CDR,
            [&data](eprosima::fastcdr::Cdr& dcdr, const eprosima::fastcdr::MemberId& mid) -> bool
            {
                bool ret_value = true;
                switch (mid.id)
                {
                                        case 0:
                                                dcdr >> data.mask();
                                            break;

                                        case 1:
                                                dcdr >> data.timestamp();
                                            break;

                                        case 2:
                                                dcdr >> data.varData();
                                            break;

                                        case 3:
                                                dcdr >> data.blobType();
                                            break;

                                        case 4:
                                                dcdr >> data.properties();
                                            break;

                    default:
                        ret_value = false;
                        break;
                }
                return ret_value;
            });
}

void serialize_key(
        eprosima::fastcdr::Cdr& scdr,
        const DSF::Var::TableDataTransferEx& data)
{
    extern void serialize_key(
            Cdr& scdr,
            const DSF::Var::TableDataTransfer& data);
    serialize_key(scdr, static_cast<const DSF::Var::TableDataTransfer&>(data));
}



