#!/bin/bash

# 向上找 .project_root 标记文件
find_project_root() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.env" ]]; then
            echo "$dir"
            return
        fi
        dir="$(dirname "$dir")"
    done
    echo "Error: 项目根目录未找到（请在项目根创建 .env" >&2
    exit 1
}

PROJECT_ROOT="$(find_project_root)"

FAST_DDS_LIB="${PROJECT_ROOT}/thirdparty/fast_dds/lib"

# 设置 LD_LIBRARY_PATH 环境变量
export LD_LIBRARY_PATH="${FAST_DDS_LIB}:$LD_LIBRARY_PATH"

echo "项目根目录: $PROJECT_ROOT"
echo "LD_LIBRARY_PATH: $LD_LIBRARY_PATH"
